# ============================================================
# Crudier CRM — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in the values below.
#   cp .env.example .env
# NEVER commit the real .env file to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Port the Express server will listen on (default: 5000)
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────
# Full connection string from your Atlas dashboard.
# Replace <username>, <password>, and <dbname> with real values.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# Name of the database to use inside the cluster
MONGO_DB_NAME=crudier

# ── Authentication / JWT ─────────────────────────────────────
# Secret used to sign access tokens (min 32 chars recommended)
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars

# Access-token lifetime (e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN=1h

# Secret used to sign refresh tokens (different from JWT_SECRET)
JWT_REFRESH_SECRET=change_me_to_another_random_secret_at_least_32_chars

# Refresh-token lifetime
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX=100

# Window size in minutes
RATE_LIMIT_WINDOW_MIN=15

# ── Mailer (Gmail SMTP) ──────────────────────────────────────
# Host address of your SMTP server (e.g., smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Enable TLS/SSL connection (true/false)
SMTP_SECURE=false

# Gmail or SMTP service user address
SMTP_USER=your-gmail-username@gmail.com

# Gmail or SMTP service app password
SMTP_PASS=your-gmail-app-password

# Email sender display header
EMAIL_FROM="Crudier CRM" <no-reply@crudier-crm.local>

